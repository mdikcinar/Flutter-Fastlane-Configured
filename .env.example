# App Store Connect API Key (required for iOS lanes)
APP_STORE_CONNECT_KEY_IDENTIFIER=ABC123DEFG
APP_STORE_CONNECT_ISSUER_ID=12345678-1234-1234-1234-1234567890ab
APP_STORE_CONNECT_PRIVATE_KEY_PATH=fastlane/AuthKey_Example123.p8
# Alternatively, set APP_STORE_CONNECT_PRIVATE_KEY with the key contents.

# Google Play Service Account (required for Play Store lanes)
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=fastlane/store_keys/example_play_store.json

# Slack webhook (optional)
SLACK_HOOK_URL=

# Firebase App Distribution token (optional)
FIREBASE_TOKEN=
